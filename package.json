{
  "name": "garry-coin",
  "version": "2.beta.0.0",
  "description": "GarryCoin Discord Bot",
  "main": "src/index.js",
  "scripts": {
    "dev-api": "nodemon src/index.js",
    "dev-bot": "nodemon src/bot.js",
    "start-api": "node src/index.js",
    "start-bot": "node src/bot.js",
    "migrate-and-start-api": "npx knex migrate:latest && npm run start-api",
    "migrate-and-start-bot": "npx knex migrate:latest && npm run start-bot",
    "register": "node src/register-commands.js",
    "grant_gc": "node src/grant_gc.js",
    "test-fgr-qe": "node src/fgr_cli.js quantitative-easing",
    "test-fgr-buyback": "node src/fgr_cli.js buyback",
    "test-fgr-announcement": "node src/fgr_cli.js announcement",
    "test-fgr-metrics": "node src/fgr_cli.js metrics",
    "test-fgr-llm": "node src/fgr_cli.js test-llm",
    "test-fgr-all": "node src/fgr_cli.js test-all",
    "test-loan-credit": "node src/loan_cli.js credit-score",
    "test-loan-create": "node src/loan_cli.js create-loan",
    "test-loan-list": "node src/loan_cli.js list-active-loans",
